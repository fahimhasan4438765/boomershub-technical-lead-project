DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=call_sessions
NODE_ENV=development
PORT=3001

PIPELINE_APP_NAME="Voice Pipeline"
PIPELINE_DEBUG=true
PIPELINE_CALL_SESSION_URL=http://localhost:3001
PIPELINE_REDIS_URL=redis://localhost:6379/0

PIPELINE_STT_PROVIDER=deepgram
PIPELINE_STT_API_KEY=your_deepgram_api_key_here

PIPELINE_LLM_PROVIDER=openai
PIPELINE_LLM_API_KEY=your_openai_api_key_here
PIPELINE_LLM_MODEL=gpt-4o-mini

PIPELINE_TTS_PROVIDER=elevenlabs
PIPELINE_TTS_API_KEY=your_elevenlabs_api_key_here
PIPELINE_TTS_VOICE_ID=your_elevenlabs_voice_id_here

PIPELINE_STT_TIMEOUT_MS=400
PIPELINE_LLM_TIMEOUT_MS=500
PIPELINE_TTS_TIMEOUT_MS=400

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_MEDIA_WS_URL=wss://your-public-domain/ws/twilio-audio
TWILIO_VOICE_WEBHOOK_URL=https://your-public-domain/twilio/voice

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws/sessions
NEXT_PUBLIC_PIPELINE_WS_URL=ws://localhost:8001/ws/test-call
