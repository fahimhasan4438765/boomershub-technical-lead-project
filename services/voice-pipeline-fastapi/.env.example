PIPELINE_APP_NAME=Voice Pipeline
PIPELINE_DEBUG=true

PIPELINE_CALL_SESSION_URL=http://localhost:3001
PIPELINE_REDIS_URL=redis://localhost:6379/0

PIPELINE_STT_PROVIDER=deepgram
PIPELINE_STT_API_KEY=

PIPELINE_LLM_PROVIDER=openai
PIPELINE_LLM_API_KEY=
PIPELINE_LLM_MODEL=gpt-4o-mini

PIPELINE_TTS_PROVIDER=openai
PIPELINE_TTS_API_KEY=
PIPELINE_TTS_VOICE_ID=
PIPELINE_TTS_VOICE=alloy
PIPELINE_TTS_MODEL=gpt-4o-mini-tts

PIPELINE_STT_TIMEOUT_MS=400
PIPELINE_LLM_TIMEOUT_MS=500
PIPELINE_TTS_TIMEOUT_MS=400

# Only needed for real Twilio Media Streams calls:
TWILIO_MEDIA_WS_URL=wss://your-public-domain/ws/twilio-audio

